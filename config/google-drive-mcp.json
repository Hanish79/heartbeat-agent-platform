{
  "schema_version": "1.0",
  "server_name": "google-drive",
  "transport": "stdio",
  "root_folder_id_env": "GOOGLE_DRIVE_FOLDER_ID",
  "tools": {
    "list_files": "drive_list_files",
    "download_file": "drive_download_file",
    "upload_file": "drive_upload_file",
    "create_folder": "drive_create_folder"
  },
  "folders": {
    "input": "01 Input Documents",
    "drafts": "02 Generated Drafts",
    "approvals": "03 Waiting for Approval",
    "approved": "04 Approved Outputs",
    "rejected": "05 Rejected Outputs"
  },
  "notes": [
    "Change only tool names if the approved Google Drive MCP server exposes different names.",
    "The rest of the repository workflow remains unchanged.",
    "Credentials must be supplied outside Git and restricted to the demo folder."
  ]
